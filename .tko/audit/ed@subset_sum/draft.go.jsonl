{"ts":1782775937,"hash":"9f33b5c76a35b5c92b77d80c5ba6d763d8262a3af9fd6bee471968074108196c","mode":"diff","ops":[{"tag":"insert","a1":30,"a2":30,"text":"\n\n\npackage main\n\nimport (\n\t\"container/list\"\n\t\"fmt\"\n)\n\ntype Queue[T any] struct {\n\titems *list.List\n}\n\nfunc NewQueue[T any]() *Queue[T] {\n\treturn &Queue[T]{items: list.New()}\n}\n\nfunc (q *Queue[T]) Enqueue(item T) {\n\tq.items.PushBack(item)\n}\n\nfunc (q *Queue[T]) Dequeue() T {\n\tif q.items.Len() == 0 {\n\t\tvar zero T\n\t\treturn zero // Return zero value if queue is empty\n\t}\n\tfront := q.items.Front().Value.(T)\n\tq.items.Remove(q.items.Front())\n\treturn front\n}\n\nfunc (q *Queue[T]) IsEmpty() bool {\n\treturn q.items.Len() == 0\n}\n\nfunc (q *Queue[T]) String() string {\n\tvar result string\n\tfor e := q.items.Front(); e != nil; e = e.Next() {\n\t\tresult += fmt.Sprint(e.Value.(T)) + \" \"\n\t}\n\treturn \"[ \" + result + \"]\"\n}\n"}]}
{"ts":1782775974,"hash":"44b8423a2ee89dac9941fd1955a82c28b628509585aaafec0390046eae4e9f45","mode":"diff","ops":[{"tag":"delete","a1":0,"a2":33,"text":""},{"tag":"insert","a1":39,"a2":39,"text":"\nfunc main() {\n\tvar n, sum int\n\tfmt.Scan(&n, &sum)\n\tnumeros := make([]int, n)\n\tfor i := 0; i < n; i++ {\n\t\tfmt.Scan(&numeros[i])\n\t}\n\tvar isSubsetSum func([]int)\n\tpath := NewQueue[T any]()\n\tisSubsetSum = func(path []int) {\n\t\tif len(path) == 2 {\n\t\t\tif path[0]+path[1] == sum {\n\t\t\t\tfmt.Println(\"true\")\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t\tfor i := 0; i < len(numeros); i++ {\n\t\t\tnumber := numeros[i]\n\t\t\tpath = append(path, number)\n\t\t\tisSubsetSum(path)\n\t\t\tpath = path[1:]\n\t\t}\n\t}\n\tisSubsetSum(path)\n}\n"}]}
