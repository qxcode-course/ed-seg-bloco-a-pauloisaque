{"ts":1782942721,"hash":"c6e9d42ad4a478fb5c7b27e87199a81e409dc3a82d9fceb9610c62f33246c9d2","mode":"diff","ops":[{"tag":"replace","a1":21,"a2":35,"text":"\tif node == nil {\n\t\treturn nil\n\t}\n\tif node.Value == value {\n\t\treturn node\n\t}\n\tif found := find(node.Left, value); found != nil {\n\t\treturn found\n\t}\n\treturn find(node.Right, value)\n"},{"tag":"replace","a1":38,"a2":39,"text":"// the height of a node is the number of nodes on the longest path from the node to a leaf\n"},{"tag":"replace","a1":40,"a2":43,"text":"\tif node == nil {\n\t\treturn 0\n"},{"tag":"replace","a1":44,"a2":46,"text":"\tleftHeight := getHeight(node.Left)\n\trightHeight := getHeight(node.Right)\n\tif leftHeight > rightHeight {\n\t\treturn leftHeight + 1\n"},{"tag":"replace","a1":47,"a2":48,"text":"\treturn rightHeight + 1\n"},{"tag":"replace","a1":54,"a2":56,"text":"\tif node == nil {\n\t\treturn 0\n\t}\n\tif node.Value == value {\n\t\treturn level\n\t}\n\tif depth := calcNodeDepth(node.Left, level+1, value); depth != 0 {\n\t\treturn depth\n\t}\n\treturn calcNodeDepth(node.Right, level+1, value)\n"}]}
